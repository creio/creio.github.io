/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=self
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://giscus.app https://cloud.umami.is https://substackapi.com https://f.convertkit.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://giscus.app https://cloud.umami.is; frame-src https://giscus.app https://ctlos.substack.com; base-uri 'self'; form-action 'self'

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.css
/*.js
/*.woff2
/*.woff
/*.ttf
/*.png
/*.jpg
/*.webp
/*.svg
/*.mp4
/*.webm
  Cache-Control: public, max-age=31536000, immutable
