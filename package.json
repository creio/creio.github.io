{
  "name": "creio-blog",
  "description": "Blogs theme hugo",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "browserslist": [
    "defaults"
  ],
  "repository": "https://github.com/creio/hugo-blog",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "create": "exec-bin node_modules/.bin/hugo/hugo new",
    "dev": "exec-bin node_modules/.bin/hugo/hugo server --bind=0.0.0.0 --disableFastRender --noHTTPCache",
    "format": "prettier **/** -w -c",
    "tina": "tinacms dev --noTelemetry -c \"exec-bin node_modules/.bin/hugo/hugo server --bind=0.0.0.0 --disableFastRender --noHTTPCache\"",
    "prebuild": "npm run clean",
    "build": "exec-bin node_modules/.bin/hugo/hugo --gc --minify --cleanDestinationDir",
    "build:preview": "npm run build -- -D -F -b /",
    "preview": "vite preview --outDir public",
    "postinstall": "hugo-installer --version otherDependencies.hugo --extended --destination node_modules/.bin/hugo",
    "clean": "shx rm -rf public resources .hugo_build.lock",
    "clean:install": "shx rm -rf package-lock.json node_modules",
    "version": "exec-bin node_modules/.bin/hugo/hugo version",
    "server": "exec-bin node_modules/.bin/hugo/hugo server",
    "test": "npm run -s lint",
    "copy:katex-fonts": "shx cp ./node_modules/katex/dist/fonts/* ./static/fonts/"
  },
  "dependencies": {
    "@thulite/seo": "^2.4.3"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@tinacms/cli": "^1.5.45",
    "@types/node": "^20.12.12",
    "auto-changelog": "^2.4.0",
    "autoprefixer": "^10.4.19",
    "bootstrap": "^5.3.3",
    "exec-bin": "^1.0.0",
    "flexsearch": "^0.8.31",
    "highlight.js": "^11.9.0",
    "hugo-installer": "^4.0.1",
    "instant.page": "^5.2.0",
    "katex": "^0.17.0",
    "lazysizes": "^5.3.2",
    "netlify-plugin-submit-sitemap": "^0.4.0",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.1",
    "purgecss-whitelister": "^2.4.0",
    "shx": "^0.4.0",
    "prettier": "^3.3.0",
    "vite": "^5.2.12"
  },
  "otherDependencies": {
    "hugo": "0.163.0"
  }
}
